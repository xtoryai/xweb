---
import { getContent, getFileContent } from '../core/content';
import { t, getFrontendLocale } from '../core/i18n-frontend';

export interface Props {
  title?: string;
  description?: string;
  hideFooter?: boolean;
}

const { title, description, hideFooter = false } = Astro.props;
const locale = getFrontendLocale(Astro.request);

const general = getFileContent('src/content/settings/general.yml') || {};
const footer = getFileContent('src/content/settings/footer.yml') || {};
const social = getFileContent('src/content/settings/social.yml') || {};
const siteTitle = title
  ? `${title} - ${general.site_title || 'News'}`
  : `${general.site_title || 'News'} - ${general.site_description || ''}`;

const theme = {
  primary: general.theme_primary || '#000000',
  bg: general.theme_bg || '#ffffff',
  accent: general.theme_accent || '#d4380d',
  text: general.theme_text || '#1a1a1a',
  muted: general.theme_muted || '#8E8E93',
  headingFont: general.theme_heading_font || 'PingFang SC',
  bodyFont: general.theme_body_font || 'PingFang SC',
  bodySize: general.theme_body_size || '16',
};

const currentPath = Astro.url.pathname;
const allPages = getContent('pages', 'src/content/pages');
const navItems = [
  { label: t('首页', locale), href: '/', icon: 'home' },
  { label: t('文章', locale), href: '/posts', icon: 'news' },
  { label: t('留言', locale), href: '/contact', icon: 'message' },
  ...allPages.filter(p => !p.data.hidden).map(p => ({
    label: p.data.title || p.slug, href: `/${p.slug}`, icon: 'page',
  })),
].map(item => ({
  ...item,
  active: item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href),
}));

const socialLinks = [
  { key: 'instagram', href: social.instagram },
  { key: 'facebook', href: social.facebook },
  { key: 'twitter', href: social.twitter },
  { key: 'youtube', href: social.youtube },
  { key: 'tiktok', href: social.tiktok },
].filter(s => s.href);

const languages = [
  { code: 'zh', label: '中文', href: '/' },
  { code: 'en', label: 'English', href: '/en/' },
];
const currentLang = languages.find(l => l.code === locale) || languages[0];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{siteTitle}</title>
  <meta name="description" content={description || general.site_description || ''} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <Fragment set:html={`<style is:inline>
    :root {
      --xt-primary: ${theme.primary}; --xt-bg: ${theme.bg}; --xt-accent: ${theme.accent};
      --xt-text: ${theme.text}; --xt-muted: ${theme.muted};
      --xt-heading-font: ${theme.headingFont}; --xt-body-font: ${theme.bodyFont};
      --xt-body-size: ${theme.bodySize}px;
      --color-bg: #fff; --color-text: #1a1a1a; --color-text-muted: #8E8E93;
      --color-border: #e5e5e5; --color-hover-bg: rgba(0,0,0,0.04);
    }
    [data-theme="dark"] {
      --color-bg: #1c1c1e; --color-text: #f5f5f7; --color-text-muted: #98989d;
      --color-border: #38383a; --color-hover-bg: rgba(255,255,255,0.06);
    }
  </style>`} />

  <style is:inline>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-font-smoothing:antialiased}
    body{font-family:var(--xt-body-font),-apple-system,BlinkMacSystemFont,'SF Pro Display','Segoe UI',sans-serif;font-size:var(--xt-body-size);color:var(--color-text);background:var(--color-bg);line-height:1.6}
    a{color:inherit;text-decoration:none}
    img{max-width:100%;height:auto}

    .mob-header{display:none;position:sticky;top:0;z-index:100;background:var(--color-bg);height:56px;padding:0 16px;align-items:center;justify-content:space-between;border-bottom:1px solid var(--color-border)}
    .mob-header button,.mob-header .search-btn{background:none;border:none;cursor:pointer;padding:8px;color:var(--color-text);display:flex;align-items:center}
    .mob-header .logo-mob{font-size:17px;font-weight:700}

    .mob-sidebar{position:fixed;top:0;left:0;z-index:90;width:260px;height:100vh;background:var(--color-bg);padding:32px 20px;overflow-y:auto;border-right:1px solid var(--color-border);transform:translateX(-100%);transition:transform .25s;display:flex;flex-direction:column}
    .mob-sidebar.open{transform:translateX(0)}
    .mob-sidebar .sb-logo{font-size:20px;font-weight:700;margin-bottom:36px;display:block}
    .mob-sidebar nav{flex:1;display:flex;flex-direction:column;gap:2px}
    .mob-sidebar nav a{display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:8px;font-size:16px;color:var(--color-text-muted);transition:background .15s,color .15s}
    .mob-sidebar nav a:hover,.mob-sidebar nav a.active{background:var(--color-hover-bg);color:var(--color-text);font-weight:600}
    .mob-sidebar nav a svg{width:22px;height:22px;flex-shrink:0}
    .mob-sidebar .sb-bot{margin-top:auto;padding-top:20px;border-top:1px solid var(--color-border)}
    .mob-sidebar .sb-theme{display:flex;gap:4px;margin-bottom:12px}
    .mob-sidebar .sb-theme button{flex:1;padding:8px;border:1px solid var(--color-border);border-radius:6px;background:none;cursor:pointer;color:var(--color-text-muted)}
    .mob-sidebar .sb-theme button.active{border-color:var(--color-text);color:var(--color-text)}
    .mob-sidebar .sb-theme button svg{width:18px;height:18px}
    .mob-sidebar .sb-social{display:flex;flex-wrap:wrap;gap:6px}
    .mob-sidebar .sb-social a{display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:6px;color:var(--color-text-muted)}
    .mob-sidebar .sb-social a:hover{background:var(--color-hover-bg);color:var(--color-text)}
    .mob-sidebar .sb-social a svg{width:18px;height:18px}

    .mob-overlay{position:fixed;inset:0;z-index:85;background:rgba(0,0,0,.35);opacity:0;pointer-events:none;transition:opacity .25s}
    .mob-overlay.show{opacity:1;pointer-events:auto}

    .desk-sidebar{width:220px;flex-shrink:0;border-right:1px solid var(--color-border);padding:32px 24px;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto}
    .desk-sidebar .ds-logo{font-size:20px;font-weight:700;margin-bottom:36px;display:block;letter-spacing:-.3px}
    .desk-sidebar nav{flex:1;display:flex;flex-direction:column;gap:2px}
    .desk-sidebar nav a{display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:8px;font-size:16px;color:var(--color-text-muted);transition:background .15s,color .15s}
    .desk-sidebar nav a:hover{background:var(--color-hover-bg);color:var(--color-text)}
    .desk-sidebar nav a.active{background:var(--color-hover-bg);color:var(--color-text);font-weight:600}
    .desk-sidebar nav a svg{width:22px;height:22px;flex-shrink:0}
    .ds-bot{margin-top:auto;padding-top:20px;border-top:1px solid var(--color-border)}
    .ds-theme{display:flex;gap:4px;margin-bottom:12px}
    .ds-theme button{flex:1;padding:8px;border:1px solid var(--color-border);border-radius:6px;background:none;cursor:pointer;color:var(--color-text-muted)}
    .ds-theme button.active{border-color:var(--color-text);color:var(--color-text)}
    .ds-theme button svg{width:18px;height:18px}
    .ds-social{display:flex;flex-wrap:wrap;gap:6px}
    .ds-social a{display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:6px;color:var(--color-text-muted)}
    .ds-social a:hover{background:var(--color-hover-bg);color:var(--color-text)}
    .ds-social a svg{width:18px;height:18px}

    .ftr{padding:32px 0;border-top:1px solid var(--color-border);text-align:center;font-size:13px;color:var(--color-text-muted)}
    .ftr a{color:var(--color-text-muted)}
    .ftr-inner{max-width:680px;margin:0 auto;padding:0 24px;line-height:2}

    @media(max-width:860px){.desk-sidebar{display:none}.mob-header{display:flex}.mob-sidebar{display:flex}}
    @media(min-width:861px){.mob-header{display:none}.mob-sidebar{display:none}.mob-overlay{display:none}}
  </style>
</head>

<body>
  <div class="mob-overlay" id="mob-overlay"></div>

  <!-- MOBILE SIDEBAR -->
  <aside class="mob-sidebar" id="mob-sidebar">
    <a href="/" class="sb-logo">{general.site_title || 'News'}</a>
    <nav>
      {navItems.map(item => (
        <a href={item.href} class={item.active ? 'active' : ''}>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            {item.icon === 'home' ? <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5zM9 21V12h6v9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/> :
             item.icon === 'news' ? <path d="M8 14h8M8 17.5h4M8 10.5h4M20 8v11a3 3 0 01-3 3H7a3 3 0 01-3-3V5a3 3 0 013-3h8.3M20 8l-5.7-6M20 8h-3.7a2 2 0 01-1.7-2V2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/> :
             item.icon === 'message' ? <path d="M12.2 21c4.8 0 8.8-4 8.8-9s-4-9-8.8-9S3.5 7 3.5 12c0 1.9.5 3.6 1.5 5 0 0-.5 2-2 3.5 3.9.5 5.4-.4 5.4-.4A8.7 8.7 0 0012.2 21z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/> :
             <path d="M4 6h16M4 12h10M4 18h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>}
          </svg>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
    <div class="sb-bot">
      <div class="sb-theme">
        <button id="mob-btn-light" class="active"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4l1.4-1.4M17 7l1.4-1.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>
        <button id="mob-btn-dark"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4.9 16.8c2.7 4.2 8.2 5.5 12.5 2.8a9 9 0 003.1-3.3c-3.5 1.3-7.6 0-9.7-3.2A8.4 8.4 0 0112.1 3a9.1 9.1 0 00-4.4 1.4A8.8 8.8 0 004.9 16.8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      </div>
      {socialLinks.length > 0 && <div class="sb-social">{socialLinks.map(s => <a href={s.href} target="_blank" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/></svg></a>)}</div>}
    </div>
  </aside>

  <!-- MOBILE HEADER -->
  <header class="mob-header">
    <button id="hamburger-btn" aria-label="Menu"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M15 17H5M19 7H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>
    <a href="/" class="logo-mob">{general.site_title || 'News'}</a>
    <a href="/?s=" class="search-btn" aria-label="Search"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M17 17l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></a>
  </header>

  <!-- DESKTOP LAYOUT -->
  <div style="display:flex;min-height:100vh">
    <aside class="desk-sidebar">
      <a href="/" class="ds-logo">{general.site_title || 'News'}</a>
      <nav>
        {navItems.map(item => (
          <a href={item.href} class={item.active ? 'active' : ''}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              {item.icon === 'home' ? <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5zM9 21V12h6v9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/> :
               item.icon === 'news' ? <path d="M8 14h8M8 17.5h4M8 10.5h4M20 8v11a3 3 0 01-3 3H7a3 3 0 01-3-3V5a3 3 0 013-3h8.3M20 8l-5.7-6M20 8h-3.7a2 2 0 01-1.7-2V2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/> :
               item.icon === 'message' ? <path d="M12.2 21c4.8 0 8.8-4 8.8-9s-4-9-8.8-9S3.5 7 3.5 12c0 1.9.5 3.6 1.5 5 0 0-.5 2-2 3.5 3.9.5 5.4-.4 5.4-.4A8.7 8.7 0 0012.2 21z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/> :
               <path d="M4 6h16M4 12h10M4 18h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>}
            </svg>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>
      <div class="ds-bot">
        <div class="ds-theme">
          <button id="btn-light" class="active"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4l1.4-1.4M17 7l1.4-1.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>
          <button id="btn-dark"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4.9 16.8c2.7 4.2 8.2 5.5 12.5 2.8a9 9 0 003.1-3.3c-3.5 1.3-7.6 0-9.7-3.2A8.4 8.4 0 0112.1 3a9.1 9.1 0 00-4.4 1.4A8.8 8.8 0 004.9 16.8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        </div>
        {socialLinks.length > 0 && <div class="ds-social">{socialLinks.map(s => <a href={s.href} target="_blank" rel="noopener"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/></svg></a>)}</div>}
      </div>
    </aside>

    <div style="flex:1;min-width:0;display:flex;flex-direction:column">
      <div style="flex:1;min-height:0;overflow:hidden;position:relative"><slot /></div>
      {!hideFooter && (
        <footer class="ftr"><div class="ftr-inner">
          <p>&copy; {new Date().getFullYear()} {footer.copyright || general.site_title || 'News'}</p>
          {footer.icp && <p><a href="https://beian.miit.gov.cn/" target="_blank" rel="nofollow">{footer.icp}</a></p>}
        </div></footer>
      )}
    </div>
  </div>

  <script is:inline>
    (function(){
      var h=document.documentElement;
      var mb=document.getElementById('mob-sidebar'),ov=document.getElementById('mob-overlay'),hb=document.getElementById('hamburger-btn');
      if(hb&&mb&&ov){hb.onclick=function(){mb.classList.add('open');ov.classList.add('show');mb.style.display='flex'};ov.onclick=function(){mb.classList.remove('open');ov.classList.remove('show')};mb.querySelectorAll('nav a').forEach(function(a){a.onclick=function(){mb.classList.remove('open');ov.classList.remove('show')}})}
      function sync(){var d=h.getAttribute('data-theme')==='dark';document.querySelectorAll('#btn-light,#mob-btn-light').forEach(function(b){b.classList.toggle('active',!d)});document.querySelectorAll('#btn-dark,#mob-btn-dark').forEach(function(b){b.classList.toggle('active',d)})}
      function set(t){if(t==='dark'){h.setAttribute('data-theme','dark');localStorage.setItem('uuwish-theme','dark')}else{h.removeAttribute('data-theme');localStorage.setItem('uuwish-theme','light')}sync()}
      if(localStorage.getItem('uuwish-theme')==='dark')h.setAttribute('data-theme','dark');sync();
      document.querySelectorAll('#btn-light,#mob-btn-light').forEach(function(b){b.onclick=function(){set('light')}});
      document.querySelectorAll('#btn-dark,#mob-btn-dark').forEach(function(b){b.onclick=function(){set('dark')}});
    })();
  </script>
</body>
</html>
