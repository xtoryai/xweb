---
import { getFileContent } from '$core/content';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const general = getFileContent('src/content/settings/general.yml') || {};
const footer = getFileContent('src/content/settings/footer.yml') || {};
const siteTitle = general.site_title || '选择性波峰焊设备';
const siteDesc = general.site_description || '';
const pageTitle = title ? `${title} - ${siteTitle}` : siteTitle;

const currentPath = Astro.url.pathname;

const nav = [
  { label: '良品率诊断', href: '/diagnosis' },
  { label: '设备', href: '/equipment' },
  { label: '案例', href: '/cases' },
  { label: '工艺知识库', href: '/knowledge-base' },
  { label: '服务', href: '/services' },
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description || siteDesc} />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <style is:inline>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root {
      --blue:#005a9c;--blue-light:#eff6ff;--green:#16a34a;--green-light:#f0fdf4;
      --red:#dc2626;--red-light:#fef2f2;--amber:#d97706;--amber-light:#fffbeb;
      --gray-50:#f8fafc;--gray-100:#f1f5f9;--gray-200:#e2e8f0;--gray-300:#cbd5e1;
      --gray-400:#94a3b8;--gray-500:#64748b;--gray-700:#334155;--gray-900:#0f172a;
    }
    body{font-family:"PingFang SC","Microsoft YaHei",-apple-system,sans-serif;color:var(--gray-900);background:#fff;line-height:1.6;-webkit-font-smoothing:antialiased}
    a{text-decoration:none;color:inherit}

    /* Nav */
    .nav-bar{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.95);backdrop-filter:blur(8px);border-bottom:1px solid var(--gray-200)}
    .nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center;height:60px;gap:24px}
    .nav-logo{font-size:17px;font-weight:700;color:var(--blue);white-space:nowrap}
    .nav-links{display:flex;gap:2px;flex:1}
    .nav-links a{padding:8px 14px;border-radius:6px;font-size:14px;font-weight:500;color:var(--gray-500);transition:all .15s}
    .nav-links a:hover{color:var(--blue);background:var(--gray-50)}
    .nav-links a.active{color:var(--blue);background:var(--blue-light)}
    .nav-cta{background:var(--blue);color:#fff;padding:8px 18px;border-radius:6px;font-size:13px;font-weight:600;white-space:nowrap}
    .nav-cta:hover{opacity:.9}
    .nav-toggle{display:none;background:none;border:none;padding:8px;cursor:pointer}
    .nav-toggle span{display:block;width:22px;height:2px;background:var(--gray-900);margin:5px 0;border-radius:1px}
    .nav-mobile{display:none;position:fixed;inset:0;z-index:60;background:#fff;flex-direction:column;padding:24px;transform:translateX(100%);transition:transform .3s}
    .nav-mobile.open{transform:translateX(0);display:flex}
    .nav-mobile-close{align-self:flex-end;background:none;border:none;font-size:28px;cursor:pointer;padding:8px}
    .nav-mobile a{display:block;padding:14px 0;font-size:17px;color:var(--gray-900);border-bottom:1px solid var(--gray-200)}

    /* Containers */
    .wrap{max-width:1200px;margin:0 auto;padding:0 24px}
    .wrap-sm{max-width:900px;margin:0 auto;padding:0 24px}
    .section{padding:80px 0}
    .section-gray{background:var(--gray-50)}
    .section-blue{background:var(--blue-light)}
    .section-dark{background:var(--gray-900);color:#fff}

    /* Hero */
    .hero{padding:80px 0 60px}
    .hero h1{font-size:clamp(26px,5vw,44px);font-weight:800;line-height:1.2;margin-bottom:16px}
    .hero h1 em{font-style:normal;color:var(--blue)}
    .hero-lead{font-size:18px;color:var(--gray-500);max-width:600px;line-height:1.8;margin-bottom:28px}
    .hero-actions{display:flex;gap:12px;flex-wrap:wrap}

    /* Buttons */
    .btn{display:inline-flex;align-items:center;gap:6px;padding:12px 28px;border-radius:8px;font-weight:600;font-size:15px;cursor:pointer;border:none;transition:all .15s}
    .btn-blue{background:var(--blue);color:#fff}.btn-blue:hover{background:#004580}
    .btn-white{background:#fff;color:var(--blue);border:1px solid var(--gray-200)}.btn-white:hover{background:var(--blue-light)}
    .btn-large{padding:16px 36px;font-size:17px}

    /* Stat cards */
    .stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px}
    .stat-card{background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:24px}
    .stat-label{font-size:13px;color:var(--gray-500);margin-bottom:4px}
    .stat-value{font-size:28px;font-weight:800;color:var(--blue)}
    .stat-desc{font-size:12px;color:var(--gray-400);margin-top:4px}

    /* Card grid */
    .card-grid{display:grid;gap:20px}
    .cols-2{grid-template-columns:repeat(auto-fill,minmax(380px,1fr))}
    .cols-3{grid-template-columns:repeat(auto-fill,minmax(320px,1fr))}
    .cols-4{grid-template-columns:repeat(auto-fill,minmax(260px,1fr))}
    .card{background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:24px;transition:all .15s;display:block}
    .card:hover{border-color:var(--blue);box-shadow:0 4px 16px rgba(0,90,156,.08)}
    .card-title{font-size:17px;font-weight:700;color:var(--gray-900);margin-bottom:8px}
    .card-meta{font-size:13px;color:var(--gray-500);margin-bottom:8px}
    .card-desc{font-size:14px;color:var(--gray-500);line-height:1.6}
    .card-tag{font-size:12px;color:var(--blue);font-weight:500}

    /* Highlight box */
    .highlight{padding:12px 16px;border-radius:8px;font-size:13px;font-weight:500;margin-top:12px}
    .highlight-green{background:var(--green-light);color:var(--green)}
    .highlight-red{background:var(--red-light);color:var(--red)}

    /* Section headers */
    .sec-label{font-size:12px;font-weight:700;color:var(--blue);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px}
    .sec-title{font-size:clamp(22px,4vw,32px);font-weight:800;color:var(--gray-900);margin-bottom:12px}
    .sec-desc{font-size:16px;color:var(--gray-500);max-width:600px;line-height:1.7}

    /* Pain cards */
    .pain-card{background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:28px}
    .pain-card .pain-icon{font-size:24px;margin-bottom:12px}
    .pain-card h3{font-size:16px;font-weight:700;color:var(--gray-900);margin-bottom:8px}
    .pain-card p{font-size:14px;color:var(--gray-500);line-height:1.7}
    .pain-card .pain-loss{font-size:13px;color:var(--red);font-weight:600;margin-top:12px;padding:8px 12px;background:var(--red-light);border-radius:6px;display:inline-block}

    /* Diagnosis form */
    .diag-form{background:#fff;border:2px solid var(--blue);border-radius:12px;padding:32px;max-width:700px;margin:0 auto}
    .diag-q{margin-bottom:24px}
    .diag-q label{display:block;font-size:15px;font-weight:600;color:var(--gray-900);margin-bottom:10px}
    .diag-opts{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px}
    .diag-opt{padding:12px 16px;border:2px solid var(--gray-200);border-radius:8px;cursor:pointer;text-align:center;font-size:14px;transition:all .15s;background:#fff}
    .diag-opt:hover{border-color:var(--blue);background:var(--blue-light)}
    .diag-opt.selected{border-color:var(--blue);background:var(--blue-light);font-weight:600}
    .diag-result{background:var(--green-light);border-radius:10px;padding:28px;text-align:center}
    .diag-result h3{font-size:22px;font-weight:800;color:var(--green);margin-bottom:12px}
    .diag-result .big-number{font-size:42px;font-weight:900;color:var(--green);display:block;margin:8px 0}

    /* Page title */
    .page-h1{font-size:30px;font-weight:800;color:var(--gray-900);margin-bottom:8px}
    .page-lead{font-size:16px;color:var(--gray-500);margin-bottom:36px}

    /* Breadcrumb */
    .crumbs{font-size:13px;color:var(--gray-400);margin-bottom:20px}
    .crumbs a{color:var(--blue)}

    /* Article */
    .article{line-height:1.9;color:var(--gray-700);font-size:15px}
    .article h2{font-size:22px;font-weight:700;color:var(--gray-900);margin:32px 0 12px}
    .article h3{font-size:17px;font-weight:700;margin:24px 0 8px}
    .article p{margin-bottom:12px}
    .article table{width:100%;border-collapse:collapse;margin:20px 0;font-size:14px}
    .article td,.article th{border:1px solid var(--gray-200);padding:10px 14px;font-size:14px;text-align:left;vertical-align:top}
    .article th{background:var(--gray-50);font-weight:700;color:var(--gray-900)}
    .article tr:nth-child(even){background:var(--gray-50)}
    .article ul,.article ol{padding-left:24px;margin:12px 0}
    .article li{margin-bottom:6px;line-height:1.7}
    .article code{background:var(--gray-100);padding:2px 6px;border-radius:3px;font-size:13px;font-family:monospace}
    .article pre{background:var(--gray-900);color:#e2e8f0;padding:16px 20px;border-radius:8px;overflow-x:auto;margin:16px 0;font-size:13px;line-height:1.6}
    .article strong{color:var(--gray-900)}
    .article hr{border:none;border-top:1px solid var(--gray-200);margin:24px 0}

    /* Pain/Solution/Result blocks */
    .block{padding:24px;border-radius:12px;margin-bottom:20px}
    .block-pain{background:var(--red-light);border:1px solid #fecaca}
    .block-pain h3{color:var(--red)}
    .block-solution{background:var(--blue-light);border:1px solid #bfdbfe}
    .block-solution h3{color:var(--blue)}
    .block-result{background:var(--green-light);border:2px solid #86efac;text-align:center}
    .block-result h3{color:var(--green)}
    .block-result .big{font-size:22px;font-weight:800;color:var(--green)}

    /* Tags */
    .tags{display:flex;flex-wrap:wrap;gap:6px}
    .tag{background:var(--blue-light);color:var(--blue);padding:3px 10px;border-radius:20px;font-size:12px}

    /* Specs box */
    .specs{background:var(--gray-50);border-radius:10px;padding:20px;font-family:monospace;font-size:13px;color:var(--gray-700);line-height:1.9;white-space:pre-wrap}

    /* Video embed */
    .video-box{aspect-ratio:16/9;background:#000;border-radius:10px;overflow:hidden;margin-bottom:24px}
    .video-box iframe{width:100%;height:100%}

    /* Form */
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
    .form-card{background:#fff;border:1px solid var(--gray-200);border-radius:12px;padding:32px}
    .form-group{margin-bottom:16px}
    .form-group label{display:block;font-size:14px;font-weight:500;color:var(--gray-700);margin-bottom:4px}
    .form-group input,.form-group textarea{width:100%;padding:10px 14px;border:1px solid var(--gray-300);border-radius:8px;font-size:14px;outline:none;font-family:inherit}
    .form-group input:focus,.form-group textarea:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(0,90,156,.08)}
    .btn-submit{width:100%;background:var(--blue);color:#fff;padding:12px;border:none;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer}
    .btn-submit:hover{opacity:.9}

    /* Contact info cards */
    .info-card{display:flex;align-items:center;gap:16px;margin-bottom:16px;padding:20px;background:var(--gray-50);border-radius:10px}
    .info-icon{font-size:26px;width:44px;height:44px;display:flex;align-items:center;justify-content:center;background:var(--blue-light);border-radius:10px;flex-shrink:0}
    .info-card strong{display:block;font-size:15px;margin-bottom:2px}
    .info-card span{font-size:14px;color:var(--gray-500)}

    /* Detail page CTA */
    .cta-block{text-align:center;padding:40px;background:var(--blue-light);border-radius:12px;margin-top:48px}
    .cta-block h3{font-size:18px;font-weight:700;color:var(--blue);margin-bottom:12px}

    /* ROI page */
    .roi-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start}
    .roi-form{padding:32px;background:#fff;border:1px solid var(--gray-200);border-radius:12px}
    .roi-result{background:var(--gray-900);color:#fff;border-radius:12px;padding:36px 32px}
    .roi-result h3{color:var(--gray-400);font-size:13px;font-weight:500;margin-bottom:4px}
    .roi-result .val{font-size:36px;font-weight:800;margin-bottom:20px}
    .roi-result .val span{font-size:16px;font-weight:400;color:var(--gray-400)}
    .roi-result .val.green{color:#4ade80}
    .roi-result .val.blue{color:#60a5fa}

    /* Selector */
    .step{display:none}
    .step.active{display:block}
    .progress{display:flex;gap:4px;margin-bottom:24px}
    .progress-bar{flex:1;height:3px;border-radius:2px;background:var(--gray-200);transition:background .3s}
    .progress-bar.done{background:var(--blue)}
    .opt-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px}
    .opt-btn{padding:20px;border:2px solid var(--gray-200);border-radius:10px;cursor:pointer;text-align:left;background:#fff;transition:all .15s;font-size:15px}
    .opt-btn:hover{border-color:var(--blue);background:var(--blue-light)}
    .opt-btn .opt-icon{font-size:28px;margin-bottom:8px}
    .opt-btn .opt-label{font-weight:600;display:block;margin-bottom:2px}
    .opt-btn .opt-hint{font-size:12px;color:var(--gray-400)}

    /* Footer */
    .site-footer{background:var(--gray-900);color:var(--gray-400);padding:60px 0 30px;font-size:14px;line-height:2}
    .footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px}
    .footer-grid h4{color:#e2e8f0;font-size:14px;margin-bottom:12px}
    .footer-grid a{color:var(--gray-400)}.footer-grid a:hover{color:#fff}
    .footer-bottom{text-align:center;padding-top:24px;border-top:1px solid #1e293b;color:var(--gray-500);font-size:13px}

    @media(max-width:768px){
      .nav-links,.nav-cta{display:none}.nav-toggle{display:block}
      .footer-grid{grid-template-columns:1fr;gap:24px}
      .form-grid,.roi-grid{grid-template-columns:1fr}
      .hero{padding:48px 0 40px}
      .cols-2,.cols-3,.cols-4{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
  <nav class="nav-bar"><div class="nav-inner">
    <a href="/" class="nav-logo">{siteTitle}</a>
    <div class="nav-links">
      {nav.map(item=><a href={item.href} class={(currentPath===item.href||(item.href!=='/'&&currentPath.startsWith(item.href)))?'active':''}>{item.label}</a>)}
    </div>
    <a href="/contact" class="nav-cta">预约诊断</a>
    <button class="nav-toggle" id="nav-toggle" aria-label="菜单"><span></span><span></span><span></span></button>
  </div></nav>
  <div class="nav-mobile" id="nav-mobile">
    <button class="nav-mobile-close" id="nav-close">&times;</button>
    {nav.map(item=><a href={item.href}>{item.label}</a>)}
    <a href="/contact" style="margin-top:12px;color:var(--blue);font-weight:600">预约诊断</a>
  </div>

  <main><slot /></main>

  <footer class="site-footer"><div class="wrap"><div class="footer-grid">
    <div><h4>{siteTitle}</h4><p>{siteDesc}</p></div>
    <div><h4>诊断工具</h4><a href="/diagnosis">良品率自测</a><br/><a href="/roi-calculator">ROI 计算器</a><br/><a href="/selector">选型向导</a></div>
    <div><h4>资源</h4><a href="/cases">客户案例</a><br/><a href="/knowledge-base">工艺知识库</a><br/><a href="/services">服务支持</a></div>
    <div><h4>联系</h4>{general.email && <p>{general.email}</p>}{general.phone && <p>{general.phone}</p>}</div>
  </div>
  <div class="footer-bottom">&copy; {new Date().getFullYear()} {siteTitle}{footer.icp && <> · <a href="https://beian.miit.gov.cn/">{footer.icp}</a></>}</div>
  </div></footer>

  <script is:inline>
    document.getElementById('nav-toggle')?.addEventListener('click',()=>document.getElementById('nav-mobile')?.classList.add('open'));
    document.getElementById('nav-close')?.addEventListener('click',()=>document.getElementById('nav-mobile')?.classList.remove('open'));
  </script>
</body>
</html>
