---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../core/content';
import { marked } from 'marked';

const { slug } = Astro.params;
const posts = getContent('posts', 'src/content/posts');
const post = posts.find(p => p.slug === slug);

if (!post) return Astro.redirect('/404');
if (post.data.link) return Astro.redirect(post.data.link);

const rawHtml = post.body ? marked.parse(post.body) : '';
---

<BaseLayout title={post.data.title} description={post.data.description} showRightSidebar={false}>
  <article class="post-article">
    <a href="/posts" class="back-link">← 返回文章列表</a>
    <div class="post-meta">
      <time datetime={post.data.date || ''}>
        {post.data.date ? new Date(post.data.date).toLocaleDateString('zh-CN', {
          year: 'numeric', month: 'long', day: 'numeric'
        }) : ''}
      </time>
      {Array.isArray(post.data.tags) && post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </div>
    <h1 class="post-title">{post.data.title}</h1>
    {post.data.description && <p class="post-desc">{post.data.description}</p>}
    {post.data.image && <img src={post.data.image} alt={post.data.title} class="post-featured-img" />}
    {rawHtml ? (
      <div class="cms-content" set:html={rawHtml} />
    ) : (
      <div class="empty-body">暂无正文内容</div>
    )}
    <footer class="post-footer">
      <a href="/posts" class="back-link">← 返回文章列表</a>
    </footer>
  </article>
</BaseLayout>

<style is:inline>
  .back-link { font-size: 14px; color: var(--color-text-muted); display: inline-block; margin-bottom: 24px; transition: color 0.15s; }
  .back-link:hover { color: var(--color-text); }
  .post-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
  .post-meta time { font-size: 14px; color: var(--color-text-muted); }
  .post-tags { display: flex; gap: 8px; }
  .tag { font-size: 12px; color: var(--color-text-muted); background: var(--color-hover-bg); padding: 2px 8px; border-radius: 4px; }
  .post-title {
    font-size: 32px; font-weight: 700; line-height: 1.25; color: var(--color-text);
    margin-bottom: 16px;
    font-family: var(--xt-heading-font), -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .post-desc { font-size: 18px; line-height: 1.7; color: var(--color-text-muted); margin-bottom: 28px; }
  .post-featured-img { width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; margin-bottom: 32px; }
  .empty-body { text-align: center; padding: 60px 0; color: var(--color-text-muted); font-size: 16px; }
  .post-footer { margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--color-border); }
  .cms-content { font-size: var(--xt-body-size); line-height: 1.9; color: var(--color-text); }
  .cms-content h2 { font-size: 24px; font-weight: 600; color: var(--color-text); margin: 2em 0 0.6em; }
  .cms-content h3 { font-size: 20px; font-weight: 600; color: var(--color-text); margin: 1.6em 0 0.5em; }
  .cms-content p { margin-bottom: 1.2em; }
  .cms-content img { max-width: 100%; border-radius: 6px; margin: 1em 0; }
  .cms-content pre { background: var(--color-hover-bg); padding: 16px; border-radius: 6px; overflow-x: auto; font-size: 14px; margin: 1em 0; }
  .cms-content code { background: var(--color-hover-bg); padding: 2px 6px; border-radius: 3px; font-size: 0.9em; }
  .cms-content blockquote { border-left: 3px solid var(--color-text); padding-left: 16px; margin: 1em 0; color: var(--color-text-muted); }
  .cms-content ul, .cms-content ol { padding-left: 1.5em; margin-bottom: 1em; }
  .cms-content li { margin-bottom: 0.4em; }
  .cms-content table { width: 100%; border-collapse: collapse; margin: 1em 0; }
  .cms-content th, .cms-content td { border: 1px solid var(--color-border); padding: 8px 12px; text-align: left; font-size: 14px; }
  .cms-content th { background: var(--color-hover-bg); font-weight: 600; }
  .cms-content hr { border: none; border-top: 1px solid var(--color-border); margin: 2em 0; }
  .cms-content a { color: var(--xt-accent); text-decoration: underline; }
</style>
