---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../core/content';
import { marked } from 'marked';
import { t, getFrontendLocale } from '../../core/i18n-frontend';

const locale = getFrontendLocale(Astro.request);

const allPosts = getContent('posts', 'src/content/posts')
  .filter(p => !p.data.draft);

// Check if a specific post is selected via ?p=slug (use regex, new URL() fails on relative paths in Astro)
const pMatch = Astro.request.url.match(/[?&]p=([^&]+)/);
const selectedSlug = pMatch ? pMatch[1] : (allPosts[0]?.slug || '');
const selectedPost = allPosts.find(p => p.slug === selectedSlug) || null;
const selectedHtml = selectedPost?.body ? marked.parse(selectedPost.body) : '';
---

<BaseLayout title={t('文章', locale)} hideFooter={true}>
  <div class="posts-layout" id="posts-layout">
    <!-- MIDDLE: Post list -->
    <div class="posts-list" id="posts-list">
      <div class="posts-list-header">
        <h2 class="pl-heading">{t('文章', locale)}</h2>
        <span class="pl-count">共 {allPosts.length} 篇</span>
      </div>
      <div class="posts-list-inner">
        {allPosts.length > 0 ? allPosts.map(post => (
          <a
            href={`/posts?p=${post.slug}`}
            class={`post-row${post.slug === selectedSlug ? ' active' : ''}`}
            data-slug={post.slug}
          >
            <span class="post-row-title">{post.data.title}</span>
            <span class="post-row-date">
              {post.data.date ? new Date(post.data.date).toLocaleDateString('zh-CN', {month:'short',day:'numeric'}) : ''}
            </span>
          </a>
        )) : (
          <div class="empty-list">还没有文章</div>
        )}
      </div>
    </div>

    <!-- RIGHT: Article content -->
    <div class="posts-content" id="posts-content">
      {selectedPost ? (
        <article class="pc-article">
          <header class="pc-header">
            <h1 class="pc-title">{selectedPost.data.title}</h1>
            <div class="pc-meta">
              <time datetime={selectedPost.data.date || ''}>
                {selectedPost.data.date ? new Date(selectedPost.data.date).toLocaleDateString('zh-CN', {
                  year: 'numeric', month: 'long', day: 'numeric'
                }) : ''}
              </time>
              {Array.isArray(selectedPost.data.tags) && selectedPost.data.tags.length > 0 && (
                <div class="pc-tags">
                  {selectedPost.data.tags.map((tag: string) => <span class="pc-tag">{tag}</span>)}
                </div>
              )}
            </div>
          </header>
          {selectedPost.data.image && (
            <img src={selectedPost.data.image} alt={selectedPost.data.title} class="pc-img" />
          )}
          {selectedHtml ? (
            <div class="cms-content" set:html={selectedHtml} />
          ) : (
            <div class="pc-empty">暂无正文内容</div>
          )}
        </article>
      ) : (
        <div class="pc-placeholder">
          <p>← 请从左侧列表选择一篇文章阅读</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style is:inline>
  /* ===== 3-column: list | content ===== */
  .posts-layout {
    position: absolute;
    inset: 0;
    display: flex;
    overflow: hidden;
  }

  /* Middle: post list */
  .posts-list {
    width: 320px;
    flex-shrink: 0;
    min-height: 0;
    border-right: 1px solid var(--color-border);
    display: flex; flex-direction: column;
    overflow: hidden;
  }
  .posts-list-header {
    padding: 24px 20px 16px;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .pl-heading {
    font-size: 20px; font-weight: 700; color: var(--color-text);
    font-family: var(--xt-heading-font), -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .pl-count { font-size: 13px; color: var(--color-text-muted); }
  .posts-list-inner {
    flex: 1; min-height: 0; overflow-y: scroll; padding: 8px 0;
    overscroll-behavior: contain;
    scrollbar-width: thin; scrollbar-color: var(--color-border) transparent;
  }
  .posts-list-inner::-webkit-scrollbar { width: 6px; }
  .posts-list-inner::-webkit-scrollbar-track { background: transparent; }
  .posts-list-inner::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }
  .post-row {
    display: flex; align-items: baseline; justify-content: space-between;
    padding: 12px 20px; cursor: pointer;
    transition: background 0.1s; gap: 12px;
    border-left: 3px solid transparent;
  }
  .post-row:hover { background: var(--color-hover-bg); }
  .post-row.active {
    background: var(--color-hover-bg);
    border-left-color: var(--color-text);
  }
  .post-row-title {
    font-size: 14px; line-height: 1.4; color: var(--color-text);
    flex: 1; min-width: 0;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .post-row-date {
    font-size: 12px; color: var(--color-text-muted);
    flex-shrink: 0;
  }
  .empty-list {
    padding: 40px 20px; text-align: center;
    color: var(--color-text-muted); font-size: 14px;
  }

  /* Right: article content */
  .posts-content {
    flex: 1; min-width: 0; min-height: 0;
    overflow-y: scroll; padding: 32px 40px;
    overscroll-behavior: contain;
    scrollbar-width: thin; scrollbar-color: var(--color-border) transparent;
  }
  .posts-content::-webkit-scrollbar { width: 6px; }
  .posts-content::-webkit-scrollbar-track { background: transparent; }
  .posts-content::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }
  .pc-placeholder {
    display: flex; align-items: center; justify-content: center;
    height: 100%; color: var(--color-text-muted); font-size: 16px;
  }
  .pc-article { max-width: 720px; }
  .pc-header { margin-bottom: 28px; }
  .pc-title {
    font-size: 28px; font-weight: 700; line-height: 1.3; color: var(--color-text);
    margin-bottom: 12px;
    font-family: var(--xt-heading-font), -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .pc-meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .pc-meta time { font-size: 14px; color: var(--color-text-muted); }
  .pc-tags { display: flex; gap: 6px; }
  .pc-tag {
    font-size: 12px; color: var(--color-text-muted);
    background: var(--color-hover-bg); padding: 2px 8px; border-radius: 4px;
  }
  .pc-img { width: 100%; max-height: 360px; object-fit: cover; border-radius: 8px; margin-bottom: 28px; }
  .pc-empty { text-align: center; padding: 60px 0; color: var(--color-text-muted); }

  /* CMS content */
  .cms-content { font-size: var(--xt-body-size); line-height: 1.9; color: var(--color-text); }
  .cms-content :global(h2) { font-size: 22px; font-weight: 600; margin: 1.8em 0 0.5em; }
  .cms-content :global(h3) { font-size: 18px; font-weight: 600; margin: 1.4em 0 0.4em; }
  .cms-content :global(p) { margin-bottom: 1em; }
  .cms-content :global(img) { max-width: 100%; border-radius: 6px; margin: 1em 0; }
  .cms-content :global(pre) { background: var(--color-hover-bg); padding: 16px; border-radius: 6px; overflow-x: auto; font-size: 14px; margin: 1em 0; }
  .cms-content :global(code) { background: var(--color-hover-bg); padding: 2px 6px; border-radius: 3px; font-size: .9em; }
  .cms-content :global(blockquote) { border-left: 3px solid var(--color-text); padding-left: 16px; margin: 1em 0; color: var(--color-text-muted); }
  .cms-content :global(ul), .cms-content :global(ol) { padding-left: 1.5em; margin-bottom: 1em; }
  .cms-content :global(li) { margin-bottom: .4em; }
  .cms-content :global(table) { width: 100%; border-collapse: collapse; margin: 1em 0; }
  .cms-content :global(th), .cms-content :global(td) { border: 1px solid var(--color-border); padding: 8px 12px; font-size: 14px; text-align: left; }
  .cms-content :global(th) { background: var(--color-hover-bg); font-weight: 600; }
  .cms-content :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 2em 0; }
  .cms-content :global(a) { color: var(--xt-accent); text-decoration: underline; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 860px) {
    .posts-layout { position: static; flex-direction: column; overflow: visible; }
    .posts-list { width: 100%; border-right: none; }
    .posts-list-inner { max-height: 45vh; overflow-y: auto; }
    .posts-content { overflow-y: visible; padding: 24px 16px; }
    .pc-article { max-width: 100%; }
    .pc-title { font-size: 24px; }
    .post-row-title { white-space: normal; }
  }
</style>
