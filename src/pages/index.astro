---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContent } from '../core/content';

const posts = getContent('posts', 'src/content/posts')
  .filter(p => !p.data.draft)
  .slice(0, 8);
---

<BaseLayout>
  <div class="home">

    <!-- ═══════ HERO ═══════ -->
    <header class="hero">
      <h1 class="hero-name">长河</h1>
      <p class="hero-meta">一个普通人跨越时代的两段人生</p>
      <div class="hero-line"></div>
    </header>

    <!-- ═══════ PULL QUOTE ═══════ -->
    <figure class="motto">
      <p>生命如长河</p>
      <p>上半段随波逐流，下半段由自己掌舵。</p>
    </figure>

    <!-- ═══════ ESSAY ═══════ -->
    <div class="prose">

      <p>如果搁在古代，我可能是一个<em>奴隶</em>；<br/>
      搁在农业时代，一个<em>老实巴交的农民</em>；<br/>
      搁在工业时代，一个<em>工厂里默默无闻的工人</em>；<br/>
      搁在商业时代，一个<em>生存都难的老板</em>。</p>

      <p>每个时代都给我贴好标签。我照着活。<br/>活了几十年。</p>

      <p>我是长河。一个计算机专业毕业的普通人，开了17年的公司，写过代码，做过营销，搞过开源。说什么都做过一点，但也说不出做成了什么。</p>

      <p class="prose-accent">反正就是跟着时代走，一直走到今天。</p>
    </div>

    <!-- ═══════ TURNING POINT ═══════ -->
    <div class="turn">
      <div class="turn-dot"></div>
      <div class="turn-body">
        <p>AI时代来了。</p>
        <p>这一次，我忽然想试试：<br/><strong>能不能不被定义，只是做自己。</strong></p>
        <p>不再是"创业者"、"技术人"、"营销专家"——<br/>这些词太重了，背着走了太久。<br/>我想把它们摘下来，轻一点。</p>
      </div>
    </div>

    <!-- ═══════ VALUES ═══════ -->
    <div class="principles">
      <div class="principle">
        <span class="principle-num">I</span>
        <div>
          <strong>不再追逐标签</strong>
          <p>不需要被叫做"创始人"、"专家"、"大佬"。我就是一个人，一个会写代码、会思考、会表达的人。</p>
        </div>
      </div>
      <div class="principle">
        <span class="principle-num">II</span>
        <div>
          <strong>只做自己相信的事</strong>
          <p>不跟风口，不追热点。把时间花在值得的事情上：写点东西、做点工具、帮几个人。</p>
        </div>
      </div>
      <div class="principle">
        <span class="principle-num">III</span>
        <div>
          <strong>不给别人添麻烦</strong>
          <p>经济独立、情绪自足。不靠贩卖焦虑赚钱，不靠收割流量生存。</p>
        </div>
      </div>
    </div>

    <p class="closing">我想帮助更多的人，但前提是我先把自己的生存问题解决好。<span class="closing-note">这是我正在学习的事。</span></p>

    <!-- ═══════ OUTRO ═══════ -->
    <div class="prose outro">
      <p>这里什么都会写一点：人生的随想、技术的折腾、创业的坑、开源的念想。不是教程，不是心得，就是一个普通人的随手记。</p>
    </div>

    <!-- ═══════ RECENT POSTS ═══════ -->
    {posts.length > 0 && (
      <div class="recent">
        <h2 class="recent-heading">近期随想</h2>
        <div class="recent-list">
          {posts.map(post => (
            <a href={`/posts?p=${post.slug}`} class="recent-item">
              <span class="recent-title">{post.data.title}</span>
              <time class="recent-date" datetime={post.data.date || ''}>
                {post.data.date ? new Date(post.data.date).toLocaleDateString('zh-CN', {month:'short', day:'numeric'}) : ''}
              </time>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style is:inline>
  /* ═══════════════════════════════════════
     TYPOGRAPHY & LAYOUT
     ═══════════════════════════════════════ */
  .home {
    max-width: 600px;
    margin: 0 auto;
    padding: 80px 28px 80px;
  }

  /* ── Hero ── */
  .hero {
    margin-bottom: 48px;
  }
  .hero-name {
    font-size: 56px;
    font-weight: 200;
    color: var(--color-text);
    letter-spacing: 16px;
    margin: 0 0 12px;
    line-height: 1.1;
    font-family: 'Noto Serif SC', 'Songti SC', 'STSong', var(--xt-heading-font), serif;
  }
  .hero-meta {
    font-size: 14px;
    color: var(--color-text-muted);
    letter-spacing: 2px;
    margin: 0;
  }
  .hero-line {
    width: 48px;
    height: 1px;
    background: var(--color-text);
    margin-top: 28px;
    opacity: 0.25;
  }

  /* ── Motto ── */
  .motto {
    margin: 0 0 56px;
    padding: 0;
  }
  .motto p {
    font-size: 22px;
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
    font-family: 'Noto Serif SC', 'Songti SC', 'STSong', var(--xt-heading-font), serif;
  }
  .motto p:first-child {
    font-size: 16px;
    color: var(--color-text-muted);
    letter-spacing: 3px;
    margin-bottom: 4px;
    font-family: var(--xt-body-font), -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* ── Prose ── */
  .prose {
    margin-bottom: 48px;
  }
  .prose p {
    font-size: 16px;
    line-height: 2;
    color: var(--color-text);
    margin: 0 0 1.5em;
  }
  .prose p:last-child { margin-bottom: 0; }
  .prose em {
    font-style: normal;
    font-weight: 600;
  }
  .prose-accent {
    font-size: 17px;
    font-weight: 500;
    color: var(--color-text);
    padding: 20px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin: 32px 0 !important;
  }

  /* ── Turning point ── */
  .turn {
    display: flex;
    gap: 20px;
    margin-bottom: 48px;
  }
  .turn-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-text);
    margin-top: 8px;
    flex-shrink: 0;
    opacity: 0.3;
  }
  .turn-body p {
    font-size: 16px;
    line-height: 2;
    color: var(--color-text);
    margin: 0 0 1.2em;
  }
  .turn-body p:last-child { margin-bottom: 0; }
  .turn-body strong { font-weight: 600; }

  /* ── Principles ── */
  .principles {
    margin-bottom: 32px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .principle {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .principle-num {
    font-size: 13px;
    font-weight: 400;
    color: var(--color-text-muted);
    padding-top: 3px;
    flex-shrink: 0;
    width: 20px;
    letter-spacing: 1px;
  }
  .principle strong {
    display: block;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .principle p {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Closing ── */
  .closing {
    font-size: 15px;
    line-height: 1.9;
    color: var(--color-text-muted);
    margin: 0 0 48px;
  }
  .closing-note {
    display: block;
    margin-top: 4px;
    font-size: 14px;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* ── Outro ── */
  .outro {
    padding-top: 20px;
    margin-bottom: 56px;
  }
  .outro p {
    font-size: 15px;
    color: var(--color-text-muted);
  }

  /* ── Recent posts ── */
  .recent {
    border-top: 1px solid var(--color-border);
    padding-top: 40px;
  }
  .recent-heading {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 20px;
  }
  .recent-list {
    display: flex;
    flex-direction: column;
  }
  .recent-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
    transition: opacity 0.2s;
  }
  .recent-item:last-child { border-bottom: none; }
  .recent-item:hover { opacity: 0.5; }
  .recent-title {
    font-size: 16px;
    color: var(--color-text);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .recent-date {
    font-size: 13px;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 860px) {
    .home { padding: 48px 20px 60px; }
    .hero-name { font-size: 40px; letter-spacing: 10px; }
    .motto p { font-size: 19px; }
    .prose p, .turn-body p { font-size: 15px; }
    .turn { gap: 14px; }
    .principles { gap: 22px; }
    .principle { gap: 14px; }
  }
</style>
