---
import BaseLayout from '$layouts/BaseLayout.astro';
import { getContent, getFileContent } from '$core/content';

const equipment = getContent('equipment', 'src/content/equipment').slice(0, 4);
const cases = getContent('cases', 'src/content/cases').filter(c => !c.data.draft).slice(0, 3);
const kb = getContent('knowledge-base', 'src/content/knowledge-base').slice(0, 3);
const general = getFileContent('src/content/settings/general.yml') || {};
---

<BaseLayout title="良品率诊断">
  <!-- ═══ Hero: 直接戳痛点 ═══ -->
  <div class="wrap">
    <section class="hero">
      <p class="sec-label">M6→M7 扩产 · 生产总监的 KPI</p>
      <h1>你们工厂过炉后<br/>人工补焊<em>一天几个工时？</em></h1>
      <p class="hero-lead">连焊、虚焊、漏焊——返修工位占着3个人，月薪+社保3万6打底，良品率卡在98%上不去。不是焊工的问题，是设备该换了。</p>
      <div class="hero-actions">
        <a href="/diagnosis" class="btn btn-blue btn-large">2 分钟良品率自测 →</a>
        <a href="/roi-calculator" class="btn btn-white btn-large">算一下能省多少</a>
      </div>
    </section>
  </div>

  <!-- ═══ 行业对标基准数据 ═══ -->
  <div class="section-gray">
    <div class="wrap" style="padding:48px 0">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;text-align:center">
        <div>
          <p style="font-size:13px;color:var(--gray-500);margin-bottom:4px">M6 电子制造 · 波峰焊良品率基准</p>
          <p style="font-size:36px;font-weight:900;color:var(--gray-900)">98.1<span style="font-size:18px;color:var(--gray-400)">%</span></p>
          <p style="font-size:13px;color:var(--gray-400)">行业平均</p>
        </div>
        <div>
          <p style="font-size:13px;color:var(--gray-500);margin-bottom:4px">前 25% 工厂达到</p>
          <p style="font-size:36px;font-weight:900;color:var(--green)">99.5<span style="font-size:18px;color:var(--gray-400)">%</span></p>
          <p style="font-size:13px;color:var(--gray-400)">你的目标</p>
        </div>
        <div>
          <p style="font-size:13px;color:var(--gray-500);margin-bottom:4px">上了选择性波峰焊的工厂</p>
          <p style="font-size:36px;font-weight:900;color:var(--blue)">8-11<span style="font-size:18px;color:var(--gray-400)"> 个月</span></p>
          <p style="font-size:13px;color:var(--gray-400)">平均回本周期</p>
        </div>
        <div>
          <p style="font-size:13px;color:var(--gray-500);margin-bottom:4px">返修工 <1人的工厂占比</p>
          <p style="font-size:36px;font-weight:900;color:var(--blue)">87<span style="font-size:18px;color:var(--gray-400)">%</span></p>
          <p style="font-size:13px;color:var(--gray-400)">基本消灭返修工位</p>
        </div>
      </div>
      <div style="text-align:center;margin-top:20px">
        <span style="font-size:15px;color:var(--gray-700);font-weight:600">你的产线在哪一档？</span>
        <a href="/diagnosis" style="display:inline-block;margin-left:12px;color:var(--blue);font-weight:700;font-size:15px">花 2 分钟测一下 →</a>
      </div>
    </div>
  </div>

  <!-- ═══ 设备实拍视频 ═══ -->
  {equipment.length > 0 && (
    <div class="wrap section" style="padding:60px 0">
      <p class="sec-label" style="text-align:center">设备实拍</p>
      <h2 class="sec-title" style="text-align:center;margin-bottom:12px">不是宣传片，是产线实拍</h2>
      <p style="text-align:center;color:var(--gray-500);margin-bottom:32px">看真实的焊接过程、操作界面和产出品质</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:20px">
        {equipment.map(item => {
          if (item.data.video_url) {
            return (
              <div class="card" style="padding:0;overflow:hidden">
                <div style="aspect-ratio:16/9;background:#000">
                  <iframe src={item.data.video_url} style="width:100%;height:100%" frameborder="0" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope" allowfullscreen></iframe>
                </div>
                <div style="padding:16px 20px">
                  <h3 class="card-title">{item.data.name}</h3>
                  {item.data.model && <p class="card-meta">型号：{item.data.model}</p>}
                </div>
              </div>
            );
          }
          return (
            <a href={`/equipment/${item.slug}`} class="card">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
                <span style="font-size:32px">🏭</span>
                <div>
                  <h3 class="card-title" style="margin-bottom:2px">{item.data.name}</h3>
                  {item.data.model && <p class="card-meta">{item.data.model}</p>}
                </div>
              </div>
              {item.data.summary && <p class="card-desc">{item.data.summary}</p>}
            </a>
          );
        })}
      </div>
    </div>
  )}

  <!-- ═══ 痛点三连 ═══ -->
  <div class="section-gray">
    <div class="wrap" style="padding:60px 0">
      <p class="sec-label" style="text-align:center">痛点诊断</p>
      <h2 class="sec-title" style="text-align:center;margin-bottom:32px">三个问题，正在吃掉你的利润</h2>
      <div class="card-grid cols-3">
        <div class="pain-card">
          <div class="pain-icon">🔧</div>
          <h3>连焊 · 虚焊 · 漏焊</h3>
          <p>插件密度一上来，传统波峰焊就扛不住。过炉出来的人工补焊，一个点就是几毛钱——乘以日产量，乘以300天。</p>
          <div class="pain-loss">典型月损失：2.5-4 万（返修工时+物料）</div>
        </div>
        <div class="pain-card">
          <div class="pain-icon">👥</div>
          <h3>熟手焊工招不到 · 留不住</h3>
          <p>一个熟手焊工 8000-12000/月。M6 扩到 M7 时订单涨了，焊工产能先爆——不是加人就能解决的。</p>
          <div class="pain-loss">3 个返修工 · 年成本 43 万</div>
        </div>
        <div class="pain-card">
          <div class="pain-icon">📉</div>
          <h3>良品率从 99%→99.5% 的坎</h3>
          <p>上游客户质量要求年年提。手工补焊一致性差，客户投诉、退货、丢订单——不是偶然，是必然。</p>
          <div class="pain-loss">每 0.1% 不良率 ≈ 年损 8-15 万</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ 产线流程对比：改前 vs 改后 ═══ -->
  <div class="wrap section" style="padding:60px 0">
    <p class="sec-label" style="text-align:center">产线流程对比</p>
    <h2 class="sec-title" style="text-align:center;margin-bottom:8px">一张图看懂：你的产线烧钱在哪</h2>
    <p style="text-align:center;color:var(--gray-500);margin-bottom:36px">中间那两个红色工位，就是你每个月烧掉的 3 万块</p>

    <!-- Before -->
    <div style="margin-bottom:40px">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px">
        <span style="background:var(--red-light);color:var(--red);padding:4px 14px;border-radius:20px;font-size:13px;font-weight:700">现在的产线</span>
        <span style="font-size:14px;color:var(--gray-500)">传统波峰焊 + 人工补焊</span>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:20px;background:#fff;border:2px solid #fecaca;border-radius:12px;overflow-x:auto">
        {[
          { label:'插件', icon:'📦', color:'#e2e8f0' },
          { label:'传统波峰焊', icon:'🔥', color:'#fef3c7' },
          { label:'过炉检验', icon:'🔍', color:'#e2e8f0' },
        ].map(s => (
          <><div style="background:{s.color};padding:12px 16px;border-radius:8px;text-align:center;min-width:90px;flex-shrink:0"><span style="display:block;font-size:20px">{s.icon}</span><span style="font-size:12px;font-weight:600;color:var(--gray-700)">{s.label}</span></div><span style="font-size:20px;color:var(--gray-300)">→</span></>
        ))}
        <div style="background:var(--red-light);border:2px solid var(--red);padding:14px 18px;border-radius:8px;text-align:center;min-width:120px;flex-shrink:0">
          <span style="display:block;font-size:28px;margin-bottom:4px">🔧</span>
          <span style="font-size:13px;font-weight:700;color:var(--red)">人工补焊</span>
          <span style="display:block;font-size:11px;color:var(--red);margin-top:4px">2-3人 · 4-8h/天</span>
        </div>
        <span style="font-size:20px;color:var(--gray-300)">→</span>
        {[
          { label:'质检', icon:'📋', color:'#e2e8f0' },
        ].map(s => (
          <><div style="background:{s.color};padding:12px 16px;border-radius:8px;text-align:center;min-width:80px;flex-shrink:0"><span style="display:block;font-size:20px">{s.icon}</span><span style="font-size:12px;font-weight:600;color:var(--gray-700)">{s.label}</span></div><span style="font-size:20px;color:var(--gray-300)">→</span></>
        ))}
        <div style="background:var(--red-light);border:2px solid var(--red);padding:14px 18px;border-radius:8px;text-align:center;min-width:100px;flex-shrink:0">
          <span style="display:block;font-size:28px;margin-bottom:4px">↩️</span>
          <span style="font-size:13px;font-weight:700;color:var(--red)">返修回流</span>
          <span style="display:block;font-size:11px;color:var(--red);margin-top:4px">不良率1-3%</span>
        </div>
        <span style="font-size:20px;color:var(--gray-300)">→</span>
        <div style="background:#e2e8f0;padding:12px 16px;border-radius:8px;text-align:center;min-width:70px;flex-shrink:0"><span style="display:block;font-size:20px">📤</span><span style="font-size:12px;font-weight:600;color:var(--gray-700)">出货</span></div>
      </div>
    </div>

    <!-- Arrow -->
    <div style="text-align:center;margin:24px 0">
      <span style="display:inline-flex;align-items:center;gap:8px;background:var(--blue-light);color:var(--blue);padding:8px 24px;border-radius:20px;font-weight:700;font-size:15px">
        ⬇ 上选择性波峰焊之后 ⬇
      </span>
    </div>

    <!-- After -->
    <div>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px">
        <span style="background:var(--green-light);color:var(--green);padding:4px 14px;border-radius:20px;font-size:13px;font-weight:700">上了选择性波峰焊</span>
        <span style="font-size:14px;color:var(--gray-500)">自动化焊接 · 极少返修</span>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:20px;background:#fff;border:2px solid #86efac;border-radius:12px;overflow-x:auto">
        {[
          { label:'插件', icon:'📦' },
          { label:'选择性波峰焊', icon:'⚡', hl:true },
          { label:'过炉目检', icon:'👀' },
        ].map(s => (
          <><div style="background:{s.hl?'var(--green-light)':'#e2e8f0'};padding:12px 16px;border-radius:8px;text-align:center;min-width:100px;flex-shrink:0{s.hl?';border:2px solid var(--green)':''}"><span style="display:block;font-size:20px">{s.icon}</span><span style="font-size:12px;font-weight:600;color:var(--gray-700)">{s.label}</span>{s.hl&&<span style="display:block;font-size:11px;color:var(--green);margin-top:4px">不良率&lt;0.3%</span>}</div><span style="font-size:20px;color:var(--gray-300)">→</span></>
        ))}
        <div style="background:var(--green-light);padding:14px 18px;border-radius:8px;text-align:center;min-width:100px;flex-shrink:0;border:2px solid var(--green)">
          <span style="display:block;font-size:28px;margin-bottom:4px">✅</span>
          <span style="font-size:13px;font-weight:700;color:var(--green)">出货</span>
          <span style="display:block;font-size:11px;color:var(--green);margin-top:4px">一次过</span>
        </div>
      </div>
    </div>

    <!-- Delta summary -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-top:28px">
      {[
        { l:'返修工位', b:'3人', a:'≤0.5人', g:'-83%' },
        { l:'不良率', b:'1-3%', a:'<0.3%', g:'-90%' },
        { l:'换线时间', b:'30-60min', a:'5min', g:'-90%' },
        { l:'年返修成本', b:'36-50万', a:'<5万', g:'省35万+' },
      ].map(r => (
        <div style="background:#fff;border:1px solid var(--gray-200);border-radius:10px;padding:16px;text-align:center">
          <p style="font-size:11px;color:var(--gray-500);margin-bottom:6px">{r.l}</p>
          <p style="font-size:13px;color:var(--red);text-decoration:line-through;margin-bottom:2px">{r.b}</p>
          <p style="font-size:16px;font-weight:700;color:var(--green)">{r.a}</p>
          <p style="font-size:12px;font-weight:600;color:#fff;background:var(--green);display:inline-block;padding:2px 10px;border-radius:10px;margin-top:4px">{r.g}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- ═══ 不换设备，先调参数（免费改善建议） ═══ -->
  <div class="wrap section" style="padding:60px 0">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center">
      <div>
        <p class="sec-label">先不急着换设备</p>
        <h2 class="sec-title">调这 3 个参数，立竿见影</h2>
        <p style="color:var(--gray-500);margin-bottom:24px;line-height:1.8">很多工厂的问题不是设备不行，是参数没调对。按这个 checklist 走一遍，可能就解决了 30% 的问题。调了还是不行——那确实该换设备了。</p>
        <div style="display:flex;flex-direction:column;gap:12px">
          {[
            { t: '预热温度 +5°C', d: '板面温度从 90→95°C，助焊剂活化更充分，虚焊减少 30%', icon: '🌡️' },
            { t: '传送带角度调到 6°', d: 'PCB 退出角度影响焊点剥离。5-7° 之间微调，连焊减少 20%', icon: '📐' },
            { t: '助焊剂喷涂量 +15%', d: '喷涂不足是桥连主因。增加喷涂量让焊盘充分润湿，桥连减少 25%', icon: '💧' },
          ].map(tip => (
            <div style="display:flex;gap:14px;padding:16px;background:#fff;border:1px solid var(--gray-200);border-radius:10px">
              <span style="font-size:28px;flex-shrink:0">{tip.icon}</span>
              <div><p style="font-weight:700;font-size:15px;margin-bottom:2px">{tip.t}</p><p style="font-size:13px;color:var(--gray-500)">{tip.d}</p></div>
            </div>
          ))}
        </div>
        <p style="margin-top:20px;font-size:14px;color:var(--gray-400)">调完还是解决不了？<a href="/diagnosis" style="color:var(--blue);font-weight:600">做个完整诊断 →</a></p>
      </div>
      <div style="background:var(--gray-50);border-radius:12px;padding:32px;text-align:center">
        <p style="font-size:60px;margin-bottom:8px">🔍</p>
        <p style="font-size:16px;font-weight:700;color:var(--gray-900);margin-bottom:8px">不知道你现在的参数对不对？</p>
        <p style="font-size:14px;color:var(--gray-500);margin-bottom:20px">我们的工程师带全套检测设备上门，花 15 分钟把你的产线参数过一遍，免费出诊断报告。</p>
        <a href="/contact" class="btn btn-blue">约免费产线诊断 →</a>
      </div>
    </div>
  </div>

  <!-- ═══ 案例：真实数据 ═══ -->
  {cases.length > 0 && (
    <div class="section-gray">
      <div class="wrap" style="padding:60px 0">
        <p class="sec-label" style="text-align:center">真实数据</p>
        <h2 class="sec-title" style="text-align:center;margin-bottom:32px">同行业工厂已经跑出来了</h2>
        <div class="card-grid cols-3">
          {cases.map(c => (
            <a href={`/cases/${c.slug}`} class="card">
              <p class="card-tag" style="margin-bottom:6px">{c.data.client} · {c.data.industry}</p>
              <h3 class="card-title">{c.data.title}</h3>
              {c.data.pain_points && <p class="card-desc" style="margin-bottom:12px">{c.data.pain_points.slice(0,80)}...</p>}
              {c.data.data_comparison && <div class="highlight highlight-green">{c.data.data_comparison}</div>}
            </a>
          ))}
        </div>
        <div style="text-align:center;margin-top:28px">
          <a href="/cases" class="btn btn-white">查看全部案例 →</a>
        </div>
      </div>
    </div>
  )}

  <!-- ═══ 工艺文章精选 ═══ -->
  {kb.length > 0 && (
    <div class="wrap section" style="padding:60px 0">
      <p class="sec-label" style="text-align:center">生产总监都在看</p>
      <h2 class="sec-title" style="text-align:center;margin-bottom:8px">不是设备说明书，是产线真问题</h2>
      <p style="text-align:center;color:var(--gray-500);margin-bottom:32px">每篇都是跑客户时积累的一手经验</p>
      <div class="card-grid cols-3">
        {kb.map(k => (
          <a href={`/knowledge-base/${k.slug}`} class="card">
            <span class="tag" style="display:inline-block;margin-bottom:8px;background:var(--gray-100);color:var(--gray-500)">{k.data.category || '工艺'}</span>
            <h3 class="card-title">{k.data.title}</h3>
            {k.data.summary && <p class="card-desc">{k.data.summary}</p>}
            <span style="display:inline-block;margin-top:12px;color:var(--blue);font-size:14px;font-weight:500">阅读 →</span>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:28px">
        <a href="/knowledge-base" class="btn btn-white">查看更多文章 →</a>
      </div>
    </div>
  )}

  <!-- ═══ 首页极简 ROI 计算 ═══ -->
  <div class="section-gray">
    <div class="wrap" style="padding:60px 0">
      <p class="sec-label" style="text-align:center">一秒钟算账</p>
      <h2 class="sec-title" style="text-align:center;margin-bottom:12px">你现在一年在返修上烧多少钱？</h2>
      <p style="text-align:center;color:var(--gray-500);margin-bottom:28px">填 3 个数，马上知道上选择性波峰焊多久回本</p>
      <div style="max-width:700px;margin:0 auto">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:24px">
          <div class="form-group"><label>返修工位几个人？</label><input type="number" id="quick-workers" value="3" min="0" style="text-align:center;font-size:18px;font-weight:700" /></div>
          <div class="form-group"><label>每人月薪（元）</label><input type="number" id="quick-salary" value="8000" min="0" style="text-align:center;font-size:18px;font-weight:700" /></div>
          <div class="form-group"><label>设备预算（万元）</label><input type="number" id="quick-cost" value="35" min="0" style="text-align:center;font-size:18px;font-weight:700" /></div>
        </div>
        <div id="quick-result" style="background:var(--gray-900);color:#fff;border-radius:12px;padding:28px 32px;text-align:center">
          <p style="color:var(--gray-400);font-size:14px;margin-bottom:4px">年返修人工成本</p>
          <p style="font-size:32px;font-weight:800;color:#4ade80;margin-bottom:4px"><span id="qr-labor">—</span></p>
          <p style="color:var(--gray-400);font-size:14px;margin-bottom:16px">上选择性波峰焊后预计返修 <1人</p>
          <p style="font-size:16px;font-weight:600"><span style="color:#60a5fa">预计回本周期：<span id="qr-payback" style="font-size:24px">—</span> 个月</span></p>
          <p style="color:var(--gray-400);font-size:13px;margin-top:12px">第二年纯省 <span id="qr-save" style="color:#4ade80;font-weight:600">—</span></p>
        </div>
        <div style="text-align:center;margin-top:20px">
          <a href="/roi-calculator" class="btn btn-blue">做更精准的 ROI 计算 →</a>
          <a href="/contact" class="btn btn-white" style="margin-left:12px">约工程师上门测算</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ CTA ═══ -->
  <div class="wrap section" style="text-align:center;padding:60px 0">
    <h2 class="sec-title">你们的产线，现在良品率多少？返修几个人？</h2>
    <p class="sec-desc" style="margin:0 auto 24px">花 2 分钟做个诊断，看看如果上选择性波峰焊，你的返修工时能压到多少、几个月回本。不做诊断，下半年还是老样子。</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a href="/diagnosis" class="btn btn-blue btn-large">开始良品率诊断 →</a>
      <a href="/contact" class="btn btn-white btn-large">直接约工程师聊</a>
    </div>
  </div>

  <script is:inline>
    function quickCalc(){const w=parseFloat(document.getElementById('quick-workers').value)||0;const s=parseFloat(document.getElementById('quick-salary').value)||0;const c=parseFloat(document.getElementById('quick-cost').value)||0;const annual=w*s*13;const after=Math.min(w,1)*s*13;const saved=annual-after;const months=c>0?Math.round((c*10000)/(saved/12)):0;document.getElementById('qr-labor').textContent=(annual/10000).toFixed(1)+' 万元/年';document.getElementById('qr-payback').textContent=months||'—';document.getElementById('qr-save').textContent=(saved/10000).toFixed(1)+' 万元/年'}
    document.querySelectorAll('#quick-workers,#quick-salary,#quick-cost').forEach(el=>el.addEventListener('input',quickCalc));quickCalc();
  </script>
</BaseLayout>
