---
import BaseLayout from '$layouts/BaseLayout.astro';
import { getContent } from '$core/content';
const items = getContent('equipment','src/content/equipment');
---
<BaseLayout title="设备中心">
  <div class="wrap section">
    <p class="sec-label">设备中心</p>
    <h1 class="page-h1">哪台设备解决你的问题？</h1>
    <p class="page-lead">从实验室打样到量产线，按你的产量和工艺需求选</p>
    <div class="card-grid cols-3">
      {items.map(item=>(<a href={`/equipment/${item.slug}`} class="card">
        <h3 class="card-title">{item.data.name}</h3>
        {item.data.model&&<p class="card-meta">型号：{item.data.model}</p>}
        {item.data.summary&&<p class="card-desc">{item.data.summary}</p>}
        {item.data.scenarios&&<div class="tags" style="margin-top:12px">{(Array.isArray(item.data.scenarios)?item.data.scenarios:[]).map(s=><span class="tag">{s}</span>)}</div>}
      </a>))}
    </div>
  </div>
</BaseLayout>
