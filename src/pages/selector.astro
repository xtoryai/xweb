---
import BaseLayout from '$layouts/BaseLayout.astro';
---
<BaseLayout title="选型向导">
  <div class="wrap section">
    <p class="sec-label">选型向导</p>
    <h1 class="page-h1">4 个问题，找到适合你的设备</h1>
    <p class="page-lead">按你的行业、产量、PCB类型、预算，我们推荐最匹配的型号</p>

    <div class="progress" id="progress">
      <div class="progress-bar done" data-s="1"></div><div class="progress-bar" data-s="2"></div><div class="progress-bar" data-s="3"></div><div class="progress-bar" data-s="4"></div>
    </div>

    <div class="step active" id="s1"><div class="diag-form"><div class="diag-q"><label>1/4 · 产品主要应用行业？</label>
      <div class="opt-grid">
        <div class="opt-btn" onclick="go(1,'汽车电子')"><span class="opt-label">🚗 汽车电子</span></div>
        <div class="opt-btn" onclick="go(1,'消费电子')"><span class="opt-label">📱 消费电子</span></div>
        <div class="opt-btn" onclick="go(1,'工业控制')"><span class="opt-label">🏭 工业控制</span></div>
        <div class="opt-btn" onclick="go(1,'医疗电子')"><span class="opt-label">🏥 医疗电子</span></div>
    </div></div></div></div>

    <div class="step" id="s2"><div class="diag-form"><div class="diag-q"><label>2/4 · 日产量规模？</label>
      <div class="opt-grid">
        <div class="opt-btn" onclick="go(2,'小批量')"><span class="opt-label">🔬 小批量/打样</span><span class="opt-hint">＜ 200 块/天</span></div>
        <div class="opt-btn" onclick="go(2,'中批量')"><span class="opt-label">⚙️ 中批量</span><span class="opt-hint">200-1000 块/天</span></div>
        <div class="opt-btn" onclick="go(2,'大批量')"><span class="opt-label">🏗️ 大批量</span><span class="opt-hint">＞ 1000 块/天</span></div>
    </div></div></div></div>

    <div class="step" id="s3"><div class="diag-form"><div class="diag-q"><label>3/4 · 主要 PCB 类型？</label>
      <div class="opt-grid">
        <div class="opt-btn" onclick="go(3,'通孔插件')"><span class="opt-label">📌 通孔插件 (THT)</span></div>
        <div class="opt-btn" onclick="go(3,'混合板')"><span class="opt-label">🔄 混合板 (SMD+THT)</span></div>
        <div class="opt-btn" onclick="go(3,'高密度')"><span class="opt-label">🔍 高密度板</span></div>
    </div></div></div></div>

    <div class="step" id="s4"><div class="diag-form"><div class="diag-q"><label>4/4 · 预算范围？</label>
      <div class="opt-grid">
        <div class="opt-btn" onclick="go(4,'经济型')"><span class="opt-label">💰 经济型</span><span class="opt-hint">15-25 万</span></div>
        <div class="opt-btn" onclick="go(4,'标准型')"><span class="opt-label">⭐ 标准型</span><span class="opt-hint">25-50 万</span></div>
        <div class="opt-btn" onclick="go(4,'高端型')"><span class="opt-label">👑 高端型</span><span class="opt-hint">50 万+</span></div>
    </div></div></div></div>

    <div class="step" id="result"><div class="diag-form" style="background:var(--blue-light);border-color:var(--blue);text-align:center">
      <div id="result-content"></div>
      <div style="margin-top:20px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a href="/equipment" class="btn btn-blue">查看设备详情</a>
        <a href="/contact" class="btn btn-white">预约演示</a>
        <a href="#" class="btn btn-white" onclick="resetSel();return false">重新选择</a>
      </div>
    </div></div>
  </div>

  <script is:inline>
    const a={};
    function go(step,answer){a[step]=answer;document.getElementById('s'+step).classList.remove('active');document.querySelectorAll('.progress-bar').forEach(b=>{if(parseInt(b.dataset.s)<=step)b.classList.add('done')});if(step<4){document.getElementById('s'+(step+1)).classList.add('active')}else{show()};document.getElementById('result').classList.add('active');document.getElementById('result').scrollIntoView({behavior:'smooth'})}
    function show(){const budget=a[4]||'',vol=a[2]||'';let m='',d='',f=[];if(budget==='高端型'||vol==='大批量'){m='WS-1200 全自动在线式波峰焊';d='大批量产线，全自动上下板+焊接+冷却一体化';f=['双轨独立控制','氮气保护，氧化减少80%','MES接口，数据可追溯']}else if(budget==='标准型'||vol==='中批量'){m='WS-800 多功能选择性波峰焊';d='中批量最佳平衡，三轴联动精度0.05mm';f=['多喷嘴可选','喷雾+预热模块','30分钟上手']}else{m='WS-400 桌面式选择性波峰焊';d='小批量/打样/实验室，占地不到1㎡';f=['单轴极简操作','220V即插即用','换喷嘴无需工具']}if(a[3]==='高密度')f.push('CCD视觉定位 精度0.02mm');if(a[1]==='医疗电子'||a[1]==='汽车电子')f.push('温度曲线记录+可追溯报告');document.getElementById('result-content').innerHTML=`<h3 style="font-size:22px;font-weight:800;color:var(--blue);margin-bottom:8px">${m}</h3><p style="font-size:16px;color:var(--gray-700);margin-bottom:16px">${d}</p><div style="background:#fff;border-radius:8px;padding:16px;text-align:left">${f.map(x=>'<p style="font-size:14px;line-height:2">✅ '+x+'</p>').join('')}</div>`}
    function resetSel(){for(let k in a)delete a[k];document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));document.getElementById('s1').classList.add('active');document.querySelectorAll('.progress-bar').forEach(b=>b.classList.remove('done'));document.querySelector('.progress-bar[data-s="1"]').classList.add('done')}
  </script>
</BaseLayout>
