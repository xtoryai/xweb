---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getFrontendLocale } from '../core/i18n-frontend';

const locale = getFrontendLocale(Astro.request);
---

<BaseLayout
  title={t('留言', locale)}
  description={t('有任何问题或建议，欢迎留言', locale)}
  showRightSidebar={false}
>
  <div class="page-wrap">
    <h1 class="contact-heading">{t('留言', locale)}</h1>
    <p class="contact-sub">有任何问题或建议，欢迎留言</p>

  <form method="POST" action="/api/contact" class="contact-form">
    <input name="name" placeholder="姓名 *" required class="form-input" />
    <input name="company" placeholder="公司" class="form-input" />
    <input name="phone" placeholder="电话 *" required class="form-input" />
    <input name="email" placeholder="邮箱" type="email" class="form-input" />
    <textarea name="message" placeholder="留言内容" rows="5" class="form-textarea"></textarea>
    <button type="submit" class="form-submit">发送</button>
    </form>
  </div>
</BaseLayout>

<style is:inline>
  .page-wrap { max-width: 680px; margin: 0 auto; padding: 32px 24px; }
  .contact-heading {
    font-size: 32px; font-weight: 700; color: var(--color-text); margin-bottom: 8px;
    font-family: var(--xt-heading-font), -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .contact-sub { font-size: 15px; color: var(--color-text-muted); margin-bottom: 36px; }
  .contact-form { display: grid; gap: 16px; }
  .form-input, .form-textarea {
    width: 100%; padding: 12px 16px;
    border: 1px solid var(--color-border); border-radius: 8px;
    font-size: 16px; font-family: inherit;
    color: var(--color-text); background: var(--color-bg);
    transition: border-color 0.15s; outline: none;
  }
  .form-input:focus, .form-textarea:focus { border-color: var(--color-text); }
  .form-textarea { resize: vertical; }
  .form-submit {
    justify-self: start; padding: 12px 32px;
    background: var(--color-text); color: var(--color-bg);
    border: none; border-radius: 8px; font-size: 16px;
    font-weight: 500; cursor: pointer; font-family: inherit;
    transition: opacity 0.15s;
  }
  .form-submit:hover { opacity: 0.85; }
</style>
