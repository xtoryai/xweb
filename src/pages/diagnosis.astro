---
import BaseLayout from '$layouts/BaseLayout.astro';
---
<BaseLayout title="良品率诊断">
  <div class="wrap section">
    <p class="sec-label">2 分钟诊断</p>
    <h1 class="page-h1">你们产线的焊接良品率处在什么水平？</h1>
    <p class="page-lead">回答下面5个问题，我们会给你一个初步的改善空间评估，以及同行业工厂的对比数据。</p>

    <div class="progress" id="progress">
      <div class="progress-bar done" data-s="1"></div>
      <div class="progress-bar" data-s="2"></div>
      <div class="progress-bar" data-s="3"></div>
      <div class="progress-bar" data-s="4"></div>
      <div class="progress-bar" data-s="5"></div>
    </div>

    <form id="diag" onsubmit="return false">
      <!-- Q1 -->
      <div class="step active" id="s1">
        <div class="diag-form">
          <div class="diag-q"><label>1/5 · 你们生产什么类型的产品？</label>
            <div class="diag-opts">
              <div class="diag-opt" onclick="go(1,'汽车电子','高可靠性、耐振动、大电流')"><span class="opt-label">🚗 汽车电子</span><span class="opt-hint">ECU、BMS、传感器</span></div>
              <div class="diag-opt" onclick="go(1,'工业控制','高功率、抗干扰')"><span class="opt-label">🏭 工业控制</span><span class="opt-hint">变频器、PLC、伺服</span></div>
              <div class="diag-opt" onclick="go(1,'消费电子','高密度、量产快')"><span class="opt-label">📱 消费电子</span><span class="opt-hint">手机、平板、穿戴</span></div>
              <div class="diag-opt" onclick="go(1,'医疗电子','超高可靠性、可追溯')"><span class="opt-label">🏥 医疗电子</span><span class="opt-hint">监护仪、影像设备</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Q2 -->
      <div class="step" id="s2">
        <div class="diag-form">
          <div class="diag-q"><label>2/5 · 过炉后人工补焊，一天几个工时？</label>
            <div class="diag-opts">
              <div class="diag-opt" onclick="go(2,'＜2小时','偶尔补焊')"><span class="opt-label">＜ 2 小时</span><span class="opt-hint">偶尔补几个点</span></div>
              <div class="diag-opt" onclick="go(2,'2-8小时','手忙脚乱')"><span class="opt-label">2-8 小时</span><span class="opt-hint">至少1个人专职补焊</span></div>
              <div class="diag-opt" onclick="go(2,'＞8小时','有3个返修工在补焊')"><span class="opt-label">＞ 8 小时</span><span class="opt-hint">2-3个人全职返修</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Q3 -->
      <div class="step" id="s3">
        <div class="diag-form">
          <div class="diag-q"><label>3/5 · 当前焊接不良率（连焊/虚焊/漏焊）大概多少？</label>
            <div class="diag-opts">
              <div class="diag-opt" onclick="go(3,'＜0.5%','良品率不错')"><span class="opt-label">＜ 0.5%</span><span class="opt-hint">99.5% 以上良品率</span></div>
              <div class="diag-opt" onclick="go(3,'0.5%-2%','正常范围')"><span class="opt-label">0.5% - 2%</span><span class="opt-hint">行业常见水平</span></div>
              <div class="diag-opt" onclick="go(3,'2%-5%','客户投诉')"><span class="opt-label">2% - 5%</span><span class="opt-hint">开始接到客户投诉</span></div>
              <div class="diag-opt" onclick="go(3,'＞5%','烧钱')"><span class="opt-label">＞ 5%</span><span class="opt-hint">大量返修，正在烧钱</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Q4 -->
      <div class="step" id="s4">
        <div class="diag-form">
          <div class="diag-q"><label>4/5 · 日产量大概多少块 PCB？</label>
            <div class="diag-opts">
              <div class="diag-opt" onclick="go(4,'＜200','小批量')"><span class="opt-label">＜ 200 块</span><span class="opt-hint">小批量/打样为主</span></div>
              <div class="diag-opt" onclick="go(4,'200-800','中批量')"><span class="opt-label">200 - 800 块</span><span class="opt-hint">典型 M6 工厂</span></div>
              <div class="diag-opt" onclick="go(4,'＞800','大批量')"><span class="opt-label">＞ 800 块</span><span class="opt-hint">M7 以上量产</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Q5 -->
      <div class="step" id="s5">
        <div class="diag-form">
          <div class="diag-q"><label>5/5 · 最近半年有没有因为焊接质量问题被客户投诉或退货？</label>
            <div class="diag-opts">
              <div class="diag-opt" onclick="go(5,'没有','零投诉')"><span class="opt-label">没有</span><span class="opt-hint">品质稳定</span></div>
              <div class="diag-opt" onclick="go(5,'1-2次','偶发')"><span class="opt-label">1-2 次</span><span class="opt-hint">偶发问题</span></div>
              <div class="diag-opt" onclick="go(5,'3次以上','高频')"><span class="opt-label">3 次以上</span><span class="opt-hint">频繁投诉，需要改善了</span></div>
            </div>
          </div>
        </div>
      </div>
    </form>

    <!-- Result -->
    <div class="step" id="result">
      <div class="diag-form">
        <div id="result-content"></div>
        <div style="text-align:center;margin-top:20px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
          <a href="/roi-calculator" class="btn btn-blue">算一下 ROI →</a>
          <a href="/contact" class="btn btn-white">约工程师现场诊断 →</a>
          <a href="#" class="btn btn-white" onclick="resetDiag();return false">重新诊断</a>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const answers = {};
    function go(step, answer) {
      answers[step] = answer;
      document.getElementById('s'+step).classList.remove('active');
      document.querySelectorAll('.progress-bar').forEach(b=>{const s=parseInt(b.dataset.s);if(s<=step)b.classList.add('done')});
      if (step < 5) { document.getElementById('s'+(step+1)).classList.add('active'); }
      else { showResult(); }
      document.getElementById('result').classList.add('active');
      document.getElementById('result').scrollIntoView({behavior:'smooth'});
    }

    function showResult() {
      const a = answers;
      const level = [a[3], a[2], a[5]].filter(x=>x&&(x.includes('＞')||x.includes('5')||x.includes('3次'))).length;
      let r = '';
      if (level >= 2) {
        r = `<div class="diag-result" style="background:var(--red-light);border-color:#fecaca"><h3 style="color:var(--red)">🔴 你的产线正在大量烧钱</h3><p style="font-size:16px;color:var(--gray-700);margin:12px 0;line-height:1.8">不良率偏高 + 返修工时多——按同行数据推估，每个月返修成本在 <strong style="color:var(--red)">2.5-5 万</strong> 之间。不是焊工的问题，是焊接方式该升级了。</p><div style="background:#fff;border-radius:8px;padding:20px;margin-top:16px;text-align:left"><p style="font-weight:700;margin-bottom:12px">同行业改善参考：</p><p>✅ 不良率 → 从 ${a[3]||'现状'} 降到 0.3% 以下</p><p>✅ 返修工时 → 3人降到0.5人</p><p>✅ 年节省 → 35-50 万</p><p>✅ 客户投诉 → 基本杜绝</p></div></div>`;
      } else if (level >= 1) {
        r = `<div class="diag-result" style="background:var(--amber-light);border-color:#fde68a"><h3 style="color:var(--amber)">⚠️ 有改善空间，投入产出比很高</h3><p style="font-size:16px;color:var(--gray-700);margin:12px 0;line-height:1.8">你的产线在这个阶段上选择性波峰焊，<strong>效果最明显</strong>——能赶在客户质量要求提高前锁定良品率。</p><div style="background:#fff;border-radius:8px;padding:20px;margin-top:16px;text-align:left"><p style="font-weight:700;margin-bottom:12px">预估改善：</p><p>✅ 返修工时 → 减少 50-70%</p><p>✅ 良品率 → 提升 0.5-1%</p><p>✅ 年节省 → 15-30 万</p></div></div>`;
      } else {
        r = `<div class="diag-result"><h3 style="color:var(--green)">✅ 产线状态不错</h3><p style="font-size:16px;color:var(--gray-700);margin:12px 0;line-height:1.8">但如果正在扩产或客户质量要求即将提高，提前布局选择性波峰焊可以帮你<strong>避免扩产期品质翻车</strong>。预防永远比救火便宜。</p></div>`;
      }
      document.getElementById('result-content').innerHTML = r;
    }

    function resetDiag() {
      for(let k in answers) delete answers[k];
      document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));
      document.getElementById('s1').classList.add('active');
      document.querySelectorAll('.progress-bar').forEach(b=>b.classList.remove('done'));
      document.querySelector('.progress-bar[data-s="1"]').classList.add('done');
    }
  </script>
</BaseLayout>
