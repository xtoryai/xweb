---
import BaseLayout from '$layouts/BaseLayout.astro';
import { getContent } from '$core/content';
const {slug}=Astro.params;const i=getContent('knowledge-base','src/content/knowledge-base').find(x=>x.slug===slug);
if(!i)return new Response(null,{status:302,headers:{Location:'/knowledge-base'}});
---
<BaseLayout title={i.data.title}>
  <article class="wrap-sm section">
    <nav class="crumbs"><a href="/">首页</a> / <a href="/knowledge-base">工艺知识库</a> / {i.data.title}</nav>
    <span class="tag" style="display:inline-block;margin-bottom:12px;background:#f3e8ff;color:#7c3aed">{i.data.category}</span>
    <h1 class="page-h1">{i.data.title}</h1>
    {i.data.video_url&&<div class="video-box"><iframe src={i.data.video_url} frameborder="0" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope" allowfullscreen></iframe></div>}
    <div class="article"><Fragment set:html={i.body||i.data.summary||''} /></div>
    <div class="cta-block"><h3>有具体的工艺问题？</h3><a href="/contact" class="btn btn-blue">问我们的工程师 →</a></div>
  </article>
</BaseLayout>
