# ── CMS Authentication (required) ──
CMS_USER=admin
CMS_PASS=admin
CMS_SECRET=your-random-secret-here

# ── API Key for external submissions (optional) ──
CMS_API_KEY=your-api-key-here

# ── Server ──
PORT=4321
HOST=0.0.0.0

# ── Git auto-commit on content changes (optional) ──
# CMS_AUTO_COMMIT=true
# CMS_AUTO_PUSH=true

# ── CMS page size (optional, default 50, max 200) ──
# CMS_PAGE_SIZE=50
